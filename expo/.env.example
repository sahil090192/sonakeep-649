# Copy this file to `.env` before running the app locally.
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the client runtime.

# Required for live gold rate fetching.
EXPO_PUBLIC_METAL_PRICE_API_KEY=your_metalpriceapi_key_here

# Optional override. Leave this as-is unless you intentionally need a different endpoint.
EXPO_PUBLIC_METAL_PRICE_API_URL=https://api.metalpriceapi.com/v1/latest
